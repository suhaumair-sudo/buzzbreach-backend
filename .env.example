# Server
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:3000

# ArangoDB
ARANGO_URL=http://localhost:8529
ARANGO_DATABASE_NAME=buzzbreach
ARANGO_USERNAME=root
ARANGO_PASSWORD=your_arango_password

# Keycloak
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=buzzbreach
KEYCLOAK_CLIENT_ID=buzzbreach-backend
KEYCLOAK_CLIENT_SECRET=your_keycloak_client_secret
KEYCLOAK_SERVER_URL=http://localhost:8080
KEYCLOAK_ISSUER=http://localhost:8080/realms/buzzbreach

# Misc
NEXT_PUBLIC_BASE_URL=http://localhost:5000
NEXT_PUBLIC_NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your_nextauth_secret
KEYCLOAK_PUBLIC_KEY=your_keycloak_public_key