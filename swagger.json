                      "type": "string"
                    }
                  },
                  "skills": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  },
                  "language": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  },
                  "education": {
                    "type": "string"
                  }
                }
              },
              "example": {
                "workExperience": "5 years at Company X",
