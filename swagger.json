  "components": {
  "securitySchemes": {
    "bearerAuth": {
      "type": "http",
      "scheme": "bearer",
      "bearerFormat": "JWT"
    }
  },
  "schemas": {
   
    "CreateEventRequest": {
  "type": "object",
  "required": ["title", "desc", "startTime", "endTime", "timeZone"],
  "properties": {
    "title": { "type": "string" },
    "desc": { "type": "string" },
    "startTime": {
      "type": "string",
      "format": "date-time"
    },
    "endTime": {
      "type": "string",
      "format": "date-time"
    },
    "timeZone": { "type": "string" },

    "organizer": { "type": "string" },
    "eventMode": { "type": "string" },
    "eventLink": { "type": "string" },
    "email": { "type": "string" },
    "tags": {
      "type": "array",
      "items": { "type": "string" }
    },
    "bannerImg": { "type": "string" },
    "lastDateOfRegistration": {
      "type": "string",
