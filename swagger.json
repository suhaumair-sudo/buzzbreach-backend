    "/user/create-individual-user": {
      "post": {
        "summary": "Create individual user",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "name": {
                    "type": "string"
                  },
                  "email": {
                    "type": "string"
                  },
                  "id": {
                    "type": "string"
                  }
                },
                "required": [
                  "name",
                  "email",
                  "id"
                ]
              },
              "example": {
                "name": "John Doe",
                "email": "john@example.com",
                "id": "keycloak-uuid-123"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "User created"
          },
          "200": {
            "description": "User already exist"
          },
          "400": {
            "description": "Bad request"
          }
        }
      }
    },
