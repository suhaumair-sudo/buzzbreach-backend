<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Interview Invitation</title>
    <style>
        /* Inline CSS styles for email compatibility */
        .container {
            font-family: Arial, sans-serif;
            padding: 20px;
            max-width: 600px; /* Maximum width of the container */
            margin: auto; /* Center the container */
        }
        .instruction-box {
            border: 2px solid #DF7B01; /* Orange border */
            border-radius: 8px; /* Rounded corners */
            padding: 20px;
            background-color: #f9f9f9; /* Light gray background */
            margin: 20px 0; /* Space around the box */
        }
        .instruction-box p {
            margin: 0 0 10px; /* Space between paragraphs */
            line-height: 1.6; /* Increase line height for readability */
        }
        .button {
            display: inline-block;
            padding: 10px 20px;
            margin-top: 10px;
            background-color: #DF7B01; /* Orange background */
            color: white;
            text-decoration: none;
            border-radius: 4px; /* Rounded corners */
            font-weight: bold;
            text-align: center; /* Center text inside button */
        }
    </style>
</head>
<body>
    <div class="container">
        <h1 style="text-align: center;">Interview Invitation</h1>
        <div class="instruction-box">
            <p><strong>Instructions:</strong> <p> <%= instruction %></p></p>
            <p>Note: The interview link will be active 5 minutes before the scheduled time.</p>
            <a href="<%= baseUrl %>/tracker/<%= applicationId %>" target="_blank" class="button">Attend Interview</a>
        </div>
    </div>
</body>
</html>
